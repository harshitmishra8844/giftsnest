# Copy to `.env` and fill in secrets. Do NOT commit `.env` to version control.
# Server configuration
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/gift-store
JWT_SECRET=replace-with-a-strong-secret

# Razorpay (optional for local testing)
RAZORPAY_DEMO_MODE=false
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Admin
ADMIN_EMAIL=admin@giftnest.com
ADMIN_PASSWORD=Admin@123

# Frontend URL (comma-separated allowed)
FRONTEND_URL=http://localhost:5173,https://your-frontend.vercel.app

# SMTP (for sending coupon emails). For Gmail, create an App Password and paste it into SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=niyoragifts@gmail.com
SMTP_PASS=cfth enwc iapc smdx
SMTP_FROM=niyoragifts@gmail.com

# Store info defaults
STORE_NAME=Gift Store
STORE_PHONE=+91-90000-00000
STORE_ADDRESS=123 Commerce Street, Mumbai, Maharashtra 400001, India
